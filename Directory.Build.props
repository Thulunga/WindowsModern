<Project>
  <PropertyGroup>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <SignAssembly>true</SignAssembly>
    <PublicKey></PublicKey>
    <AssemblyOriginatorKeyFile>$(MSBuildThisFileDirectory)Soti.MobiControl.WindowsModern.snk</AssemblyOriginatorKeyFile>
    <NoWarn>NU1507</NoWarn>
    <LangVersion>latest</LangVersion>
    <!--612 [Obsolete] attribute-->
    <!--618 [Obsolete] attribute-->
    <!--NU1903 known high severity vulnerability.-->
    <WarningsNotAsErrors>$(WarningsNotAsErrors);612;618;NU1903</WarningsNotAsErrors>
    <SotiObfuscate_Flags>PrivateFields, PrivateMethods, PrivateTypes, PrivateParameters, Generics, Namespaces, Events, GenericParameters</SotiObfuscate_Flags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Soti.CodeQuality.Settings">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Soti.Obfuscate.Task">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
</Project>
